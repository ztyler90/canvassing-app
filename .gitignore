node_modules/
dist/
.env
.env.local
.DS_Store
.tmp-syntax/

# Customer / homeowner PII and internal models — never commit
*.xlsx
*.xls
~$*
.~lock.*
KnockIQ_D2D_Prospects_*
KnockIQ_Revenue_Model*

# Capacitor / iOS — generated by Pods and Xcode, never check in.
# The ios/App folder ITSELF should be committed (it contains your project
# configuration), but the dependencies installed inside it shouldn't.
ios/App/Pods/
ios/App/Podfile.lock
ios/.gitkeep
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/DerivedData/

# Android — same pattern: project goes in, build artifacts stay out.
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/.idea/
android/captures/
