# Copy this file to .env and fill in your values

# Supabase — get these from your project's Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Google Maps reverse geocoding (more accurate than Nominatim)
# If left blank, the app falls back to free OpenStreetMap Nominatim
VITE_GOOGLE_MAPS_API_KEY=

# Stripe — get your publishable key from Stripe Dashboard > Developers > API Keys
# Use pk_test_... for development, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# PostHog product analytics — Project Settings > Project API Key.
# Leave blank to disable analytics entirely (no SDK init, nothing sent).
# Host defaults to US Cloud; only set VITE_POSTHOG_HOST to override.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Cloudflare Turnstile (login/signup CAPTCHA) — Turnstile dashboard > site key.
# Leave blank to disable the captcha widget (auth screens work unchanged).
# You must also paste the Turnstile SECRET key into Supabase:
# Authentication > Attack Protection > Enable CAPTCHA (provider: Turnstile).
VITE_TURNSTILE_SITE_KEY=
